{
    "info": {
        "name": "Repargo Platform APIs",
        "description": "Complete Postman suite hitting Auth, Users, Booking Lifecycle, Tracking, and Admin tools.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Authentication & Accounts",
            "item": [
                {
                    "name": "Send OTP Verification",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"phone\": \"+919876543210\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/send-otp",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "send-otp"
                            ]
                        }
                    }
                },
                {
                    "name": "Login/Verify Exchange",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"phone\": \"+919876543210\",\n  \"otp\": \"123456\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Bookings Lifecycle",
            "item": [
                {
                    "name": "1. Dispatch Matching Background Job",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"serviceId\": \"64d1f...\",\n  \"deviceBrand\": \"Apple\",\n  \"deviceModel\": \"iPhone 13\",\n  \"issue\": \"Screen Broken\",\n  \"coordinates\": [77.209, 28.613],\n  \"cost\": 2999\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/bookings/create",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "bookings",
                                "create"
                            ]
                        }
                    }
                },
                {
                    "name": "2. Update Status (Tech Interaction)",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{tech_token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"bookingId\": \"BKG_123\",\n  \"status\": \"En_Route\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/bookings/update-status",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "bookings",
                                "update-status"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Tracking & Notifications",
            "item": [
                {
                    "name": "FCM Token Sync",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"fcmToken\": \"expo_secure_push_xyz\",\n  \"model\": \"Customer\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/notifications/sync-token",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "notifications",
                                "sync-token"
                            ]
                        }
                    }
                },
                {
                    "name": "Ping Current Location",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{tech_token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"coordinates\": [77.21, 28.614]\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/technicians/location-update",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "technicians",
                                "location-update"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Administration",
            "item": [
                {
                    "name": "Tech Approval Gate",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/technicians/approve?id=TCH_001",
                            "host": [
                                "{{baseUrl}}"
                            ]
                        }
                    }
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:5001"
        },
        {
            "key": "token",
            "value": "CUSTOMER_JWT"
        },
        {
            "key": "tech_token",
            "value": "TECHNICIAN_JWT"
        },
        {
            "key": "admin_token",
            "value": "ADMIN_JWT"
        }
    ]
}