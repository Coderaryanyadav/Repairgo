# CORE SYSTEM
NODE_ENV=production
PORT=5000

# MONGODB (Atlas Cluster Configuration)
# Note: DO NOT APPEND LOCALHOST! Use the exact standard connection string from MongoDB Atlas Database View -> Connect.
MONGODB_URI=mongodb+srv://<USER>:<PASSWORD>@<CLUSTER_ID>.mongodb.net/repargo?retryWrites=true&w=majority

# REDIS (Managed Caching & Queues)
# If using Render or Railway, assign the internal host metric safely mapped.
REDIS_HOST=redis.internal.railway.app
REDIS_PORT=6379

# AUTHENTICATION
# Important: Generate a random SHA256 string for this mapping!
JWT_SECRET=production_secure_hashing_string

# RAZORPAY INTEGRATIONS (Payment Lifecycle)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# FIREBASE CONFIGURATION (Push Notification JSON)
FIREBASE_PROJECT_ID=repargo-production-app
FIREBASE_CLIENT_EMAIL=admin@repargo.iam.gserviceaccount.com
# IMPORTANT: Format Private Key with explicit `\n` carriage returns to parse natively as JSON!
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...-----END PRIVATE KEY-----\n"

# LOGGING
LOG_LEVEL=info
