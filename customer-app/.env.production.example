# Map these locally for EXPO / RN
# MUST MATCH backend URL! 
# If running iPhone Simulator: http://localhost:5000 
# If running Android Simulator: http://10.0.2.2:5000 (Avoids Localhost looping on VM)
EXPO_PUBLIC_API_URL=https://api.repargo.com
EXPO_PUBLIC_WEBSOCKET_URL=https://api.repargo.com

# Razorpay publishable/public key for the native mobile checkout SDK
EXPO_PUBLIC_RAZORPAY_KEY=rzp_live_xxxxxxxxxxxxxxxx
